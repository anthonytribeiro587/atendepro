# =================================================================
# AtendePRO — Environment Variables
# Copy this file to .env and fill in your values.
#
# DEPLOYMENT_MODE=selfhosted  →  instalação própria
# DEPLOYMENT_MODE=saas        →  modo multiempresa por subdomínio
# =================================================================

# ── Deployment mode ────────────────────────────────────────────────
NEXT_PUBLIC_DEPLOYMENT_MODE=selfhosted

# ── Supabase ────────────────────────────────────────────────────────
# Create a free project at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct connection URL (port 5432), NOT the pooler (port 6543)
# Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# IMPORTANT for self-hosted installs:
# Disable email confirmation in Supabase Dashboard so registration works without email verification:
# Dashboard → Authentication → Providers → Email → uncheck "Confirm email" → Save
# AtendePRO handles auto-login after registration in selfhosted mode even without this,
# but disabling it keeps Auth state clean.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── App URL ─────────────────────────────────────────────────────────
# Your app's public URL (used for booking page links, emails, etc.)
# Self-hosted: set to your domain, e.g. https://mysalon.com
# Local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email notifications ─────────────────────────────────────────────
# Option 1: Resend (easiest — free tier 3 000 emails/mo)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=AtendePRO <noreply@yourdomain.com>

# Option 2: Any SMTP server (takes priority over Resend if set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-password
# SMTP_FROM=AtendePRO <noreply@example.com>

# ── Telegram bot (optional) ────────────────────────────────────────
# Optional fallback — overrides the per-business token set in Settings → Notifications.
# Most users set the token directly in the app UI and don't need this env var.
# Create a bot via @BotFather in Telegram, paste the token in Settings → Notifications.
# Clients link their profile by sending /link {phone} to the bot.
TELEGRAM_BOT_TOKEN=

# ── Viber bot (optional) ────────────────────────────────────────────
# Optional fallback — overrides the per-business token set in Settings → Notifications.
# Most users set the token directly in the app UI and don't need this env var.
# Create a Public Account bot at partners.viber.com, paste the auth token in Settings → Notifications
VIBER_BOT_TOKEN=
# The webhook URL Viber will call — set automatically when you click "Connect" in Settings
# (only needed if you want to pre-configure before deployment)
# VIBER_WEBHOOK_URL=https://yourdomain.com/api/viber/webhook

# ── WhatsApp notifications (optional) ───────────────────────────────
# Sends booking confirmations & reminders to clients via WhatsApp.
# Client's WhatsApp number is stored per-client in CRM → Edit client → WhatsApp.
#
# Setup steps:
#   1. Go to developers.facebook.com → My Apps → Create App
#      Choose type: Business → give it a name → Create
#
#   2. In the App dashboard → Add Product → WhatsApp → Set Up
#
#   3. WhatsApp → API Setup:
#      - "Phone Number ID" → copy to META_WHATSAPP_PHONE_NUMBER_ID below
#      - "Temporary access token" → copy to META_WHATSAPP_ACCESS_TOKEN (for testing only)
#
#   4. For production (permanent token):
#      - Go to Business Settings → System Users → Add system user (Admin role)
#      - Generate token → select your App → grant whatsapp_business_messaging permission
#      - Copy the permanent token to META_WHATSAPP_ACCESS_TOKEN
#
#   5. To send to any number (not just test numbers):
#      - WhatsApp → API Setup → Add phone number → verify via SMS/call
#      - Submit your account for Meta Business Verification (required for production)
#
# Note: Meta's test sandbox only delivers to numbers you explicitly add in
# "To" field under API Setup. For real clients you need a verified business number.
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=

# ── Cron jobs ────────────────────────────────────────────────────────
# Protects the /api/cron/notify endpoint from unauthorized calls.
# Anyone who knows this secret can trigger notification sending — keep it private.
#
# How to generate a secure random value:
#   On Linux/Mac:  openssl rand -hex 32
#   On Windows:    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   Online:        https://generate-secret.vercel.app/32
#
# The migration runner substitutes this value into 007_cron_jobs.sql automatically — no manual editing needed.
CRON_SECRET=replace-with-random-string

# ── Internal API security ────────────────────────────────────────────
# Internal server-to-server auth. Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=


# ── Domain redirect ──────────────────────────────────────────────────
# Set your domain for www → non-www redirect (301 permanent).
# Exemplo: APP_DOMAIN=agenda.suaempresa.com.br redireciona www para o domínio principal
# Leave empty to disable (e.g. for self-hosted installs without a www subdomain).
APP_DOMAIN=

# Opcional: desative o PWA durante diagnóstico de build
DISABLE_PWA=false
