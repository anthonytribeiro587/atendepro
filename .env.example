# =================================================================
# AtendePRO — Environment Variables
# =================================================================

# ── Deployment mode ────────────────────────────────────────────────
NEXT_PUBLIC_DEPLOYMENT_MODE=selfhosted

# ── Supabase ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Public URLs ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_DOMAIN=

# ── WhatsApp — Evolution API (recommended for tests) ───────────────
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=http://your-evolution-server:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=your-instance-name
# Compatibility alias accepted by the code:
# EVOLUTION_INSTANCE_NAME=your-instance-name

# ── WhatsApp — Meta Cloud API (optional alternative) ───────────────
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=

# ── Email notifications (optional) ─────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=AtendePRO <noreply@yourdomain.com>
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ── Other notification providers (optional) ────────────────────────
TELEGRAM_BOT_TOKEN=
VIBER_BOT_TOKEN=

# ── Internal security ───────────────────────────────────────────────
CRON_SECRET=replace-with-random-string
INTERNAL_API_SECRET=replace-with-another-random-string

# ── Build diagnostics ───────────────────────────────────────────────
DISABLE_PWA=false
